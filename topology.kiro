        "results": {
          "tooluse_8maes9OAOceVkNVyguPKyA": {
            "tool": {
              "tool_use_purpose": "Creating topology generators for all 6 topologies",
              "kind": {
                "BuiltIn": {
                  "FileWrite": {
                    "command": "create",
                    "path": "network-topology/src/topologies.ts",
                    "content": "/**\n * topologies.ts\n * Generator functions for each network topology from Tema 4.\n * Each function returns { nodes, links } as plain config objects\n * ready to be fed into NetworkGraph.\n */\n\nimport { NodeConfig } from './NetworkNode'\n\nexport interface LinkDef {\n  sourceId: string\n  targetId: string\n}\n\nexport interface TopologyData {\n  nodes: NodeConfig[]\n  links: LinkDef[]\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// Helper: spacing constant\nconst S = 2.8\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * MESH (Malla) — k-ary 2-mesh\n * A regular 2D grid of k×k switches, each with one endpoint attached.\n * @param k Number of switches per dimension (default 4 → 4×4 = 16 switches)\n */\nexport function generateMesh(k = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const offset = ((k - 1) * S) / 2\n\n  for (let row = 0; row < k; row++) {\n    for (let col = 0; col < k; col++) {\n      const id = `sw_${row}_${col}`\n      nodes.push({\n        id,\n        label: `SW(${row},${col})`,\n        type: 'switch',\n        position: { x: col * S - offset, y: 0, z: row * S - offset },\n      })\n\n      // Link to right neighbour\n      if (col + 1 < k) {\n        links.push({ sourceId: id, targetId: `sw_${row}_${col + 1}` })\n      }\n      // Link to bottom neighbour\n      if (row + 1 < k) {\n        links.push({ sourceId: id, targetId: `sw_${row + 1}_${col}` })\n      }\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * TORUS (Toroide) — k-ary 2-cube\n * Same as mesh but with wrap-around links in each dimension.\n * @param k Number of switches per dimension (default 4)\n */\nexport function generateTorus(k = 4): TopologyData {\n  const { nodes, links } = generateMesh(k)\n\n  // Add wrap-around links\n  for (let row = 0; row < k; row++) {\n    // Horizontal wrap: last col → first col\n    links.push({ sourceId: `sw_${row}_${k - 1}`, targetId: `sw_${row}_0` })\n  }\n  for (let col = 0; col < k; col++) {\n    // Vertical wrap: last row → first row\n    links.push({ sourceId: `sw_${k - 1}_${col}`, targetId: `sw_0_${col}` })\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * WK-RECURSIVE\n * Level-1: k nodes fully interconnected (clique).\n * Level-2: k copies of level-1, each copy's \"free port\" node connects to\n *          the corresponding node in a level-2 clique.\n * We show WK(4,2): k=4, level=2  → 4 groups of 4 nodes = 16 nodes.\n */\nexport function generateWKRecursive(k = 4, level = 2): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  if (level === 1) {\n    // Single clique of k nodes\n    for (let i = 0; i < k; i++) {\n      const angle = (2 * Math.PI * i) / k\n      nodes.push({\n        id: `n_${i}`,\n        label: `N${i}`,\n        type: 'router',\n        position: {\n          x: Math.cos(angle) * S * 1.2,\n          y: 0,\n          z: Math.sin(angle) * S * 1.2,\n        },\n      })\n    }\n    // Full clique links\n    for (let i = 0; i < k; i++) {\n      for (let j = i + 1; j < k; j++) {\n        links.push({ sourceId: `n_${i}`, targetId: `n_${j}` })\n      }\n    }\n    return { nodes, links }\n  }\n\n  // Level 2: k groups arranged in a ring of groups\n  const groupRadius = S * (k === 4 ? 3.8 : 3.0)\n  const innerRadius = S * 1.1\n\n  for (let g = 0; g < k; g++) {\n    const groupAngle = (2 * Math.PI * g) / k\n    const cx = Math.cos(groupAngle) * groupRadius\n    const cz = Math.sin(groupAngle) * groupRadius\n\n    for (let i = 0; i < k; i++) {\n      const nodeAngle = (2 * Math.PI * i) / k\n      const id = `g${g}_n${i}`\n      nodes.push({\n        id,\n        label: `G${g}N${i}`,\n        type: 'router',\n        position: {\n          x: cx + Math.cos(nodeAngle) * innerRadius,\n          y: 0,\n          z: cz + Math.sin(nodeAngle) * innerRadius,\n        },\n      })\n    }\n\n    // Intra-group clique (all pairs except the \"free\" node which is node 0)\n    for (let i = 1; i < k; i++) {\n      for (let j = i + 1; j < k; j++) {\n        links.push({ sourceId: `g${g}_n${i}`, targetId: `g${g}_n${j}` })\n      }\n    }\n  }\n\n  // Inter-group links: node 0 of group g connects to node 0 of each other group\n  // (the \"free\" ports form the level-2 clique)\n  for (let g = 0; g < k; g++) {\n    for (let h = g + 1; h < k; h++) {\n      links.push({ sourceId: `g${g}_n0`, targetId: `g${h}_n0` })\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * FAT TREE (k-ary n-tree)\n * A complete binary fat tree with n stages.\n * k=2, n=3 → 4 leaf nodes, 2 stage-1 switches, 1 root switch.\n * k=2, n=4 → 8 leaves, 4+2+1 switches.\n * We use k=2, n=4 for a nice display (15 total switches, 8 endpoint nodes).\n */\nexport function generateFatTree(k = 2, n = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const leafCount = Math.pow(k, n - 1)       // number of leaf switches\n  const totalLevels = n                       // 1 root + (n-1) intermediate + leaf\n\n  // Build switches level by level (level 0 = root, level n-1 = leaf)\n  for (let lvl = 0; lvl < totalLevels; lvl++) {\n    const countAtLevel = Math.pow(k, lvl)\n    const xSpread = (leafCount - 1) * S\n    const spacing = countAtLevel > 1 ? xSpread / (countAtLevel - 1) : 0\n    const xStart = countAtLevel > 1 ? -xSpread / 2 : 0\n    const y = (totalLevels - 1 - lvl) * S * 1.6\n\n    for (let i = 0; i < countAtLevel; i++) {\n      const id = `sw_l${lvl}_${i}`\n      nodes.push({\n        id,\n        label: `L${lvl}S${i}`,\n        type: lvl === 0 ? 'router' : 'switch',\n        position: {\n          x: xStart + i * spacing,\n          y,\n          z: 0,\n        },\n      })\n    }\n  }\n\n  // Add endpoint nodes at the bottom (attached to leaf switches)\n  const endpointCount = leafCount * k\n  const xSpread = (endpointCount - 1) * S\n  const spacing = endpointCount > 1 ? xSpread / (endpointCount - 1) : 0\n  for (let i = 0; i < endpointCount; i++) {\n    const id = `ep_${i}`\n    nodes.push({\n      id,\n      label: `EP${i}`,\n      type: 'server',\n      position: {\n        x: -xSpread / 2 + i * spacing,\n        y: -(S * 1.6),\n        z: 0,\n      },\n    })\n  }\n\n  // Links: each switch at level lvl connects to k children at level lvl+1\n  for (let lvl = 0; lvl < totalLevels - 1; lvl++) {\n    const parentCount = Math.pow(k, lvl)\n    for (let p = 0; p < parentCount; p++) {\n      for (let c = 0; c < k; c++) {\n        const childIdx = p * k + c\n        links.push({\n          sourceId: `sw_l${lvl}_${p}`,\n          targetId: `sw_l${lvl + 1}_${childIdx}`,\n        })\n      }\n    }\n  }\n\n  // Links: leaf switches to endpoint nodes\n  for (let sw = 0; sw < leafCount; sw++) {\n    for (let c = 0; c < k; c++) {\n      const epIdx = sw * k + c\n      links.push({\n        sourceId: `sw_l${totalLevels - 1}_${sw}`,\n        targetId: `ep_${epIdx}`,\n      })\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * FLATTENED BUTTERFLY\n * A k-ary n-fly where switches in each column are collapsed into one.\n * We represent: 4 rows × 4 columns = 16 switches.\n * Each switch connects to every other switch in its row AND every other switch in its column.\n */\nexport function generateFlattenedButterfly(p = 4, q = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const xOffset = ((q - 1) * S * 1.5) / 2\n  const zOffset = ((p - 1) * S * 1.5) / 2\n\n  for (let row = 0; row < p; row++) {\n    for (let col = 0; col < q; col++) {\n      nodes.push({\n        id: `sw_${row}_${col}`,\n        label: `SW(${row},${col})`,\n        type: 'switch',\n        position: {\n          x: col * S * 1.5 - xOffset,\n          y: 0,\n          z: row * S * 1.5 - zOffset,\n        },\n      })\n    }\n  }\n\n  // Row connections: all-to-all within each row\n  for (let row = 0; row < p; row++) {\n    for (let c1 = 0; c1 < q; c1++) {\n      for (let c2 = c1 + 1; c2 < q; c2++) {\n        links.push({ sourceId: `sw_${row}_${c1}`, targetId: `sw_${row}_${c2}` })\n      }\n    }\n  }\n\n  // Column connections: all-to-all within each column\n  for (let col = 0; col < q; col++) {\n    for (let r1 = 0; r1 < p; r1++) {\n      for (let r2 = r1 + 1; r2 < p; r2++) {\n        links.push({ sourceId: `sw_${r1}_${col}`, targetId: `sw_${r2}_${col}` })\n      }\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * BUS (Shared-Medium Network)\n * All nodes connect to a single shared bus segment.\n * Represented as a central bus node with all endpoints connected to it.\n */\nexport function generateBus(nodeCount = 8): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  // Central bus represented as a switch\n  nodes.push({\n    id: 'bus',\n    label: 'BUS',\n    type: 'switch',\n    position: { x: 0, y: 0, z: 0 },\n  })\n\n  const types: Array<NodeConfig['type']> = ['server', 'client', 'router']\n\n  for (let i = 0; i < nodeCount; i++) {\n    const angle = (2 * Math.PI * i) / nodeCount\n    const id = `node_${i}`\n    nodes.push({\n      id,\n      label: `Node${i}`,\n      type: types[i % types.length],\n      position: {\n        x: Math.cos(angle) * S * 2.2,\n        y: 0,\n        z: Math.sin(angle) * S * 2.2,\n      },\n    })\n    links.push({ sourceId: 'bus', targetId: id })\n  }\n\n  return { nodes, links }\n}\n"
                  }
                }
              }
            },
