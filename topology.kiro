                    "path": "network-topology/src/style.css",
                    "oldStr": "/* ── Scrollbar styling ────────────────────────────────────────────────────── */",
                    "newStr": "/* ── Parameter form ───────────────────────────────────────────────────────── */\n.params-section {\n  margin-bottom: 18px;\n  padding-bottom: 14px;\n  border-bottom: 1px solid rgba(77, 208, 225, 0.15);\n}\n\n.params-section h3,\n.features-section h3 {\n  font-size: 11px;\n  font-weight: 700;\n  letter-spacing: 1.2px;\n  text-transform: uppercase;\n  color: #4dd0e1;\n  margin-bottom: 10px;\n}\n\n#params-form {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.param-row {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.param-label {\n  font-size: 11px;\n  color: #90a4ae;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 4px;\n}\n\n.param-hint {\n  font-weight: 400;\n  color: #546e7a;\n  font-style: italic;\n}\n\n.param-input {\n  background: rgba(255, 255, 255, 0.06);\n  border: 1px solid rgba(77, 208, 225, 0.25);\n  border-radius: 6px;\n  color: #e0f7fa;\n  font-size: 13px;\n  font-family: monospace;\n  padding: 6px 10px;\n  outline: none;\n  transition: border-color 0.15s, background 0.15s;\n  width: 100%;\n}\n\n.param-input:focus {\n  border-color: #4dd0e1;\n  background: rgba(77, 208, 225, 0.1);\n}\n\n/* Remove spinners from number inputs */\n.param-input[type='number']::-webkit-inner-spin-button,\n.param-input[type='number']::-webkit-outer-spin-button {\n  opacity: 0.4;\n}\n\n.rebuild-btn {\n  margin-top: 6px;\n  background: rgba(77, 208, 225, 0.15);\n  border: 1px solid #4dd0e1;\n  border-radius: 7px;\n  color: #4dd0e1;\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 0.5px;\n  padding: 8px 0;\n  cursor: pointer;\n  transition: background 0.15s, color 0.15s;\n  width: 100%;\n}\n\n.rebuild-btn:hover {\n  background: rgba(77, 208, 225, 0.3);\n  color: #ffffff;\n}\n\n.rebuild-btn:active {\n  background: rgba(77, 208, 225, 0.45);\n}\n\n/* ── Scrollbar styling ────────────────────────────────────────────────────── */",
                    "replaceAll": false
                  }
                }
              }
            },
            "result": {
              "Success": {
                "items": [
                  {
                    "Text": "Successfully replaced 1 occurrence(s) in /home/jose/Simulador_topologia_red/network-topology/src/style.css."
                  }
                ]
              }
            }
          }
        }
      }
