                    "newStr": "// ─── FLATTENED BUTTERFLY ─────────────────────────────────────────────────────\n\n// Row links (horizontal connections): warm amber\nconst BUTTERFLY_ROW_COLOR = 0xffa726\n// Column links (vertical connections): violet\nconst BUTTERFLY_COL_COLOR = 0xce93d8\n\nexport function generateFlattenedButterfly(params: FlatButterflyParams): TopologyData {\n  const p = clamp(params.p, 2, 8)\n  const q = clamp(params.q, 2, 8)\n\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const xOffset = ((q - 1) * S * 1.5) / 2\n  const zOffset = ((p - 1) * S * 1.5) / 2\n\n  for (let row = 0; row < p; row++) {\n    for (let col = 0; col < q; col++) {\n      nodes.push({\n        id: `sw_${row}_${col}`,\n        label: `SW(${row},${col})`,\n        type: 'switch',\n        position: { x: col * S * 1.5 - xOffset, y: 0, z: row * S * 1.5 - zOffset },\n      })\n    }\n  }\n\n  // All-to-all within each row — arc upward (Y+), amber color.\n  // Arc increases with the hop distance so non-adjacent pairs rise higher\n  // and don't overlap with adjacent pairs.\n  for (let row = 0; row < p; row++) {\n    for (let c1 = 0; c1 < q; c1++) {\n      for (let c2 = c1 + 1; c2 < q; c2++) {\n        const dist = c2 - c1  // 1 = adjacent, higher = farther\n        links.push({\n          sourceId: `sw_${row}_${c1}`,\n          targetId: `sw_${row}_${c2}`,\n          arc: 0.18 + dist * 0.14,\n          color: BUTTERFLY_ROW_COLOR,\n        })\n      }\n    }\n  }\n\n  // All-to-all within each column — arc in Z+ direction (forward), violet color.\n  // Same distance-proportional arc to separate pairs.\n  for (let col = 0; col < q; col++) {\n    for (let r1 = 0; r1 < p; r1++) {\n      for (let r2 = r1 + 1; r2 < p; r2++) {\n        const dist = r2 - r1\n        links.push({\n          sourceId: `sw_${r1}_${col}`,\n          targetId: `sw_${r2}_${col}`,\n          arc: -(0.18 + dist * 0.14), // negative arc bows toward Z- to separate from row arcs\n          color: BUTTERFLY_COL_COLOR,\n        })\n      }\n    }\n  }\n\n  return { nodes, links }\n}",
