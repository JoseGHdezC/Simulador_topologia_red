                  {
                    "Text": "/**\n * topologies.ts\n * Generator functions for each network topology from Tema 4.\n * Each function returns { nodes, links } as plain config objects\n * ready to be fed into NetworkGraph.\n */\n\nimport { NodeConfig } from './NetworkNode'\n\nexport interface LinkDef {\n  sourceId: string\n  targetId: string\n}\n\nexport interface TopologyData {\n  nodes: NodeConfig[]\n  links: LinkDef[]\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// Helper: spacing constant\nconst S = 2.8\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * MESH (Malla) — k-ary 2-mesh\n * A regular 2D grid of k×k switches, each with one endpoint attached.\n * @param k Number of switches per dimension (default 4 → 4×4 = 16 switches)\n */\nexport function generateMesh(k = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const offset = ((k - 1) * S) / 2\n\n  for (let row = 0; row < k; row++) {\n    for (let col = 0; col < k; col++) {\n      const id = `sw_${row}_${col}`\n      nodes.push({\n        id,\n        label: `SW(${row},${col})`,\n        type: 'switch',\n        position: { x: col * S - offset, y: 0, z: row * S - offset },\n      })\n\n      // Link to right neighbour\n      if (col + 1 < k) {\n        links.push({ sourceId: id, targetId: `sw_${row}_${col + 1}` })\n      }\n      // Link to bottom neighbour\n      if (row + 1 < k) {\n        links.push({ sourceId: id, targetId: `sw_${row + 1}_${col}` })\n      }\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * TORUS (Toroide) — k-ary 2-cube\n * Same as mesh but with wrap-around links in each dimension.\n * @param k Number of switches per dimension (default 4)\n */\nexport function generateTorus(k = 4): TopologyData {\n  const { nodes, links } = generateMesh(k)\n\n  // Add wrap-around links\n  for (let row = 0; row < k; row++) {\n    // Horizontal wrap: last col → first col\n    links.push({ sourceId: `sw_${row}_${k - 1}`, targetId: `sw_${row}_0` })\n  }\n  for (let col = 0; col < k; col++) {\n    // Vertical wrap: last row → first row\n    links.push({ sourceId: `sw_${k - 1}_${col}`, targetId: `sw_0_${col}` })\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * WK-RECURSIVE\n * Level-1: k nodes fully interconnected (clique).\n * Level-2: k copies of level-1, each copy's \"free port\" node connects to\n *          the corresponding node in a level-2 clique.\n * We show WK(4,2): k=4, level=2  → 4 groups of 4 nodes = 16 nodes.\n */\nexport function generateWKRecursive(k = 4, level = 2): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  if (level === 1) {\n    // Single clique of k nodes\n    for (let i = 0; i < k; i++) {\n      const angle = (2 * Math.PI * i) / k\n      nodes.push({\n        id: `n_${i}`,\n        label: `N${i}`,\n        type: 'router',\n        position: {\n          x: Math.cos(angle) * S * 1.2,\n          y: 0,\n          z: Math.sin(angle) * S * 1.2,\n        },\n      })\n    }\n    // Full clique links\n    for (let i = 0; i < k; i++) {\n      for (let j = i + 1; j < k; j++) {\n        links.push({ sourceId: `n_${i}`, targetId: `n_${j}` })\n      }\n    }\n    return { nodes, links }\n  }\n\n  // Level 2: k groups arranged in a ring of groups\n  const groupRadius = S * (k === 4 ? 3.8 : 3.0)\n  const innerRadius = S * 1.1\n\n  for (let g = 0; g < k; g++) {\n    const groupAngle = (2 * Math.PI * g) / k\n    const cx = Math.cos(groupAngle) * groupRadius\n    const cz = Math.sin(groupAngle) * groupRadius\n\n    for (let i = 0; i < k; i++) {\n      const nodeAngle = (2 * Math.PI * i) / k\n      const id = `g${g}_n${i}`\n      nodes.push({\n        id,\n        label: `G${g}N${i}`,\n        type: 'router',\n        position: {\n          x: cx + Math.cos(nodeAngle) * innerRadius,\n          y: 0,\n          z: cz + Math.sin(nodeAngle) * innerRadius,\n        },\n      })\n    }\n\n    // Intra-group clique (all pairs except the \"free\" node which is node 0)\n    for (let i = 1; i < k; i++) {\n      for (let j = i + 1; j < k; j++) {\n        links.push({ sourceId: `g${g}_n${i}`, targetId: `g${g}_n${j}` })\n      }\n    }\n  }\n\n  // Inter-group links: node 0 of group g connects to node 0 of each other group\n  // (the \"free\" ports form the level-2 clique)\n  for (let g = 0; g < k; g++) {\n    for (let h = g + 1; h < k; h++) {\n      links.push({ sourceId: `g${g}_n0`, targetId: `g${h}_n0` })\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * FAT TREE (k-ary n-tree)\n * A complete binary fat tree with n stages.\n * k=2, n=3 → 4 leaf nodes, 2 stage-1 switches, 1 root switch.\n * k=2, n=4 → 8 leaves, 4+2+1 switches.\n * We use k=2, n=4 for a nice display (15 total switches, 8 endpoint nodes).\n */\nexport function generateFatTree(k = 2, n = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const leafCount = Math.pow(k, n - 1)       // number of leaf switches\n  const totalLevels = n                       // 1 root + (n-1) intermediate + leaf\n\n  // Build switches level by level (level 0 = root, level n-1 = leaf)\n  for (let lvl = 0; lvl < totalLevels; lvl++) {\n    const countAtLevel = Math.pow(k, lvl)\n    const xSpread = (leafCount - 1) * S\n    const spacing = countAtLevel > 1 ? xSpread / (countAtLevel - 1) : 0\n    const xStart = countAtLevel > 1 ? -xSpread / 2 : 0\n    const y = (totalLevels - 1 - lvl) * S * 1.6\n\n    for (let i = 0; i < countAtLevel; i++) {\n      const id = `sw_l${lvl}_${i}`\n      nodes.push({\n        id,\n        label: `L${lvl}S${i}`,\n        type: lvl === 0 ? 'router' : 'switch',\n        position: {\n          x: xStart + i * spacing,\n          y,\n          z: 0,\n        },\n      })\n    }\n  }\n\n  // Add endpoint nodes at the bottom (attached to leaf switches)\n  const endpointCount = leafCount * k\n  const xSpread = (endpointCount - 1) * S\n  const spacing = endpointCount > 1 ? xSpread / (endpointCount - 1) : 0\n  for (let i = 0; i < endpointCount; i++) {\n    const id = `ep_${i}`\n    nodes.push({\n      id,\n      label: `EP${i}`,\n      type: 'server',\n      position: {\n        x: -xSpread / 2 + i * spacing,\n        y: -(S * 1.6),\n        z: 0,\n      },\n    })\n  }\n\n  // Links: each switch at level lvl connects to k children at level lvl+1\n  for (let lvl = 0; lvl < totalLevels - 1; lvl++) {\n    const parentCount = Math.pow(k, lvl)\n    for (let p = 0; p < parentCount; p++) {\n      for (let c = 0; c < k; c++) {\n        const childIdx = p * k + c\n        links.push({\n          sourceId: `sw_l${lvl}_${p}`,\n          targetId: `sw_l${lvl + 1}_${childIdx}`,\n        })\n      }\n    }\n  }\n\n  // Links: leaf switches to endpoint nodes\n  for (let sw = 0; sw < leafCount; sw++) {\n    for (let c = 0; c < k; c++) {\n      const epIdx = sw * k + c\n      links.push({\n        sourceId: `sw_l${totalLevels - 1}_${sw}`,\n        targetId: `ep_${epIdx}`,\n      })\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * FLATTENED BUTTERFLY\n * A k-ary n-fly where switches in each column are collapsed into one.\n * We represent: 4 rows × 4 columns = 16 switches.\n * Each switch connects to every other switch in its row AND every other switch in its column.\n */\nexport function generateFlattenedButterfly(p = 4, q = 4): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  const xOffset = ((q - 1) * S * 1.5) / 2\n  const zOffset = ((p - 1) * S * 1.5) / 2\n\n  for (let row = 0; row < p; row++) {\n    for (let col = 0; col < q; col++) {\n      nodes.push({\n        id: `sw_${row}_${col}`,\n        label: `SW(${row},${col})`,\n        type: 'switch',\n        position: {\n          x: col * S * 1.5 - xOffset,\n          y: 0,\n          z: row * S * 1.5 - zOffset,\n        },\n      })\n    }\n  }\n\n  // Row connections: all-to-all within each row\n  for (let row = 0; row < p; row++) {\n    for (let c1 = 0; c1 < q; c1++) {\n      for (let c2 = c1 + 1; c2 < q; c2++) {\n        links.push({ sourceId: `sw_${row}_${c1}`, targetId: `sw_${row}_${c2}` })\n      }\n    }\n  }\n\n  // Column connections: all-to-all within each column\n  for (let col = 0; col < q; col++) {\n    for (let r1 = 0; r1 < p; r1++) {\n      for (let r2 = r1 + 1; r2 < p; r2++) {\n        links.push({ sourceId: `sw_${r1}_${col}`, targetId: `sw_${r2}_${col}` })\n      }\n    }\n  }\n\n  return { nodes, links }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n/**\n * BUS (Shared-Medium Network)\n * All nodes connect to a single shared bus segment.\n * Represented as a central bus node with all endpoints connected to it.\n */\nexport function generateBus(nodeCount = 8): TopologyData {\n  const nodes: NodeConfig[] = []\n  const links: LinkDef[] = []\n\n  // Central bus represented as a switch\n  nodes.push({\n    id: 'bus',\n    label: 'BUS',\n    type: 'switch',\n    position: { x: 0, y: 0, z: 0 },\n  })\n\n  const types: Array<NodeConfig['type']> = ['server', 'client', 'router']\n\n  for (let i = 0; i < nodeCount; i++) {\n    const angle = (2 * Math.PI * i) / nodeCount\n    const id = `node_${i}`\n    nodes.push({\n      id,\n      label: `Node${i}`,\n      type: types[i % types.length],\n      position: {\n        x: Math.cos(angle) * S * 2.2,\n        y: 0,\n        z: Math.sin(angle) * S * 2.2,\n      },\n    })\n    links.push({ sourceId: 'bus', targetId: id })\n  }\n\n  return { nodes, links }\n}"
                  },
                  {
                    "Text": "/**\n * topologyMeta.ts\n * Metadata and feature descriptions for each topology, based on Tema 4.\n */\n\nimport {\n  generateMesh,\n  generateTorus,\n  generateWKRecursive,\n  generateFatTree,\n  generateFlattenedButterfly,\n  generateBus,\n  TopologyData,\n} from './topologies'\n\nexport type TopologyId =\n  | 'mesh'\n  | 'torus'\n  | 'wk-recursive'\n  | 'fat-tree'\n  | 'flattened-butterfly'\n  | 'bus'\n\nexport interface TopologyFeature {\n  label: string\n  value: string\n}\n\nexport interface TopologyMeta {\n  id: TopologyId\n  name: string\n  subtitle: string\n  description: string\n  features: TopologyFeature[]\n  generate: () => TopologyData\n}\n\nexport const TOPOLOGIES: TopologyMeta[] = [\n  {\n    id: 'mesh',\n    name: 'Malla (Mesh)',\n    subtitle: 'k-ary 2-mesh — Topología directa ortogonal',\n    description:\n      'Red en malla genérica definida como k-ary n-mesh: k^n switches distribuidos en n dimensiones. ' +\n      'Los switches están acoplados a nodos finales y se conectan con sus vecinos ortogonales. ' +\n      'La malla 2D es el caso más común (n=2). Los hipercubos son el único subconjunto simétrico y homogéneo (2-ary n-mesh). ' +\n      'En general, las k-ary n-mesh no son simétricas ni homogéneas.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Dimensiones', value: '2D (k-ary 2-mesh)' },\n      { label: 'Nº de switches', value: 'k² (ej. 4×4 = 16)' },\n      { label: 'Grado de switch', value: '2–4 (bordes/esquinas vs. interior)' },\n      { label: 'Hop count máx.', value: '2(k−1)  ej. k=4 → 6' },\n      { label: 'Bisection BW', value: 'k × ancho de enlace' },\n      { label: 'Simetría', value: 'No (excepto hipercubo)' },\n      { label: 'Homogeneidad', value: 'No (grado varía en bordes)' },\n      { label: 'Conectividad', value: '2 (nodos de esquina)' },\n      { label: 'Tolerancia a fallos', value: 'Baja en nodos de esquina' },\n      { label: 'Routing típico', value: 'DOR (XY routing)' },\n      { label: 'Uso típico', value: 'Chips multiprocesador, NoC' },\n    ],\n    generate: () => generateMesh(4),\n  },\n  {\n    id: 'torus',\n    name: 'Toroide (Torus)',\n    subtitle: 'k-ary 2-cube — Malla con enlaces circulares',\n    description:\n      'Un toroide se construye añadiendo enlaces \"circulares\" (wrap-around) a la malla equivalente. ' +\n      'Esto reduce el hop count y aumenta el bisection bandwidth y la conectividad respecto a la malla. ' +\n      'A igualdad de k y n, el toroide provee mejor desempeño y tolerancia a fallos que la malla, ' +\n      'a costa de un mayor número de enlaces. El toroide doblado (folded torus) soluciona los problemas de latencia ' +\n      'de los enlaces envolventes largos.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Dimensiones', value: '2D (k-ary 2-cube)' },\n      { label: 'Nº de switches', value: 'k² (ej. 4×4 = 16)' },\n      { label: 'Grado de switch', value: '4 (todos los switches, homogéneo)' },\n      { label: 'Hop count máx.', value: '⌊k/2⌋ × 2  ej. k=4 → 4' },\n      { label: 'Bisection BW', value: '2k × ancho de enlace' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí (todos los switches iguales)' },\n      { label: 'Conectividad', value: '4' },\n      { label: 'Tolerancia a fallos', value: 'Alta (caminos alternativos)' },\n      { label: 'Routing típico', value: 'DOR, XY-YX con canales virtuales' },\n      { label: 'Uso típico', value: 'Supercomputadores, HPC (ej. Cray Torus)' },\n    ],\n    generate: () => generateTorus(4),\n  },\n  {\n    id: 'wk-recursive',\n    name: 'WK-Recursiva',\n    subtitle: 'Topología directa regular no ortogonal',\n    description:\n      'Topología construida replicando recursivamente un nodo virtual (clique de k nodos con k enlaces libres). ' +\n      'Un nodo virtual de nivel l se construye usando k nodos virtuales de nivel l−1. ' +\n      'Parámetros: k (tamaño del clique base) y l (nivel de expansión). ' +\n      'Los enlaces libres de cada grupo de nivel l−1 se usan para interconectar los grupos en el nivel l.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, no ortogonal' },\n      { label: 'Parámetros', value: 'k (grado clique), l (nivel)' },\n      { label: 'Nº de nodos', value: 'k^l  (ej. k=4, l=2 → 16)' },\n      { label: 'Grado de switch', value: 'k−1 intra-grupo + 1 inter-grupo' },\n      { label: 'Hop count máx.', value: 'O(l)' },\n      { label: 'Bisection BW', value: 'k^(l−1) enlaces inter-grupo' },\n      { label: 'Simetría', value: 'Sí (dentro del nivel)' },\n      { label: 'Homogeneidad', value: 'Sí' },\n      { label: 'Conectividad', value: 'k−1' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Recursivo / jerárquico' },\n      { label: 'Uso típico', value: 'NoC, diseños escalables embebidos' },\n    ],\n    generate: () => generateWKRecursive(4, 2),\n  },\n  {\n    id: 'fat-tree',\n    name: 'Fat Tree',\n    subtitle: 'k-ary n-tree — Topología indirecta basada en árbol',\n    description:\n      'Topología regular e indirecta basada en árboles completos que se hacen \"más anchos\" (mayor ancho de banda) ' +\n      'cerca de la raíz. Pertenece a la familia bMIN (bidirectional Multistage Interconnection Network). ' +\n      'Los switches están organizados en etapas; solo los switches de la primera etapa tienen conexión con nodos finales. ' +\n      'Las implementaciones con switches de tamaño fijo se conocen como butterfly fat-tree o folded butterfly.',\n    features: [\n      { label: 'Tipo', value: 'Indirecta, regular, multietapa' },\n      { label: 'Parámetros', value: 'k (grado), n (etapas)' },\n      { label: 'Nº de switches', value: 'k^n − 1 switches  (ej. k=2,n=4 → 15)' },\n      { label: 'Nº de nodos finales', value: 'k^(n−1) × k' },\n      { label: 'Hop count máx.', value: '2(n−1)' },\n      { label: 'Bisection BW', value: 'Crece con k cerca de la raíz' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'No (grado varía por etapa)' },\n      { label: 'Conectividad', value: 'Alta (múltiples caminos raíz)' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Up-Down (up*/down*)' },\n      { label: 'Uso típico', value: 'Centros de datos, clusters HPC (ej. InfiniBand)' },\n    ],\n    generate: () => generateFatTree(2, 4),\n  },\n  {\n    id: 'flattened-butterfly',\n    name: 'Flattened Butterfly',\n    subtitle: 'Evolución del butterfly con switches colapsados',\n    description:\n      'Evolución de la topología butterfly en la que los switches de cada columna se colapsan en un único ' +\n      'switch de mayor grado, manteniendo las conexiones entre switches. La topología resultante es regular y ortogonal, ' +\n      'y provee el mismo bisection bandwidth que la butterfly original pero con un hop count menor, ' +\n      'a costa de un mayor grado de switch.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Parámetros', value: 'p filas, q columnas' },\n      { label: 'Nº de switches', value: 'p × q' },\n      { label: 'Grado de switch', value: '(q−1) + (p−1) (conexiones fila + columna)' },\n      { label: 'Hop count máx.', value: '2 (un salto fila + un salto columna)' },\n      { label: 'Bisection BW', value: 'Igual que butterfly original' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí (todos los switches tienen igual grado)' },\n      { label: 'Conectividad', value: 'Alta' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Dimension Order, adaptativo' },\n      { label: 'Uso típico', value: 'Datacenters, HPC de alta densidad' },\n    ],\n    generate: () => generateFlattenedButterfly(4, 4),\n  },\n  {\n    id: 'bus',\n    name: 'Bus (Medio Compartido)',\n    subtitle: 'Red de medio compartido — La más simple',\n    description:\n      'La forma más sencilla de conectar varios dispositivos: todos comparten el mismo medio de red. ' +\n      'Solo un dispositivo puede transmitir a la vez. Puede operar en modo half-dúplex (una dirección a la vez) ' +\n      'o full-dúplex. Es la topología con menor coste de implementación pero el cuello de botella ' +\n      'crece rápidamente con el número de nodos, limitando seriamente el ancho de banda total.',\n    features: [\n      { label: 'Tipo', value: 'Medio compartido' },\n      { label: 'Nº de nodos', value: 'N (ej. 8)' },\n      { label: 'Grado de nodo', value: '1 (conexión directa al bus)' },\n      { label: 'Hop count máx.', value: '2 (src → bus → dst)' },\n      { label: 'Bisection BW', value: 'Ancho de banda del bus / 2' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí' },\n      { label: 'Conectividad', value: '1 (un único punto de fallo)' },\n      { label: 'Tolerancia a fallos', value: 'Muy baja (SPOF: bus)' },\n      { label: 'Modo operación', value: 'Half-dúplex o Full-dúplex' },\n      { label: 'Routing típico', value: 'Broadcast (todos reciben, filtran por destino)' },\n      { label: 'Uso típico', value: 'Ethernet clásica, buses internos de sistema' },\n    ],\n    generate: () => generateBus(8),\n  },\n]\n\nexport function getTopology(id: TopologyId): TopologyMeta | undefined {\n  return TOPOLOGIES.find(t => t.id === id)\n}"
                  },
                  {
                    "Text": "/**\n * TopologyInfo.ts\n * Info panel that displays topology name, description, and features.\n */\n\nimport { TopologyMeta } from './topologyMeta'\n\nexport class TopologyInfo {\n  private container: HTMLElement\n\n  constructor() {\n    this.container = document.getElementById('topology-info')!\n  }\n\n  show(topology: TopologyMeta): void {\n    const featuresHTML = topology.features\n      .map(\n        f => `\n      <tr>\n        <td class=\"feat-label\">${f.label}</td>\n        <td class=\"feat-value\">${f.value}</td>\n      </tr>\n    `\n      )\n      .join('')\n\n    this.container.innerHTML = `\n      <div class=\"info-header\">\n        <h2>${topology.name}</h2>\n        <p class=\"info-subtitle\">${topology.subtitle}</p>\n      </div>\n      <p class=\"info-description\">${topology.description}</p>\n      <h3>Características</h3>\n      <table class=\"features-table\">\n        <tbody>${featuresHTML}</tbody>\n      </table>\n    `\n    this.container.style.display = 'block'\n  }\n\n  hide(): void {\n    this.container.style.display = 'none'\n  }\n}"
                  },
                  {
                    "Text": "import * as THREE from 'three'\nimport { OrbitControls } from 'three/addons/controls/OrbitControls.js'\nimport { NetworkGraph } from './NetworkGraph'\nimport { NetworkNode } from './NetworkNode'\nimport { Tooltip } from './Tooltip'\nimport { TopologySelector } from './TopologySelector'\nimport { TopologyInfo } from './TopologyInfo'\nimport { TopologyId, getTopology } from './topologyMeta'\n\n// ─── Scene setup ─────────────────────────────────────────────────────────────\n\nconst scene = new THREE.Scene()\nscene.background = new THREE.Color(0x0a1628)\nscene.fog = new THREE.FogExp2(0x0a1628, 0.028)\n\nconst camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 300)\ncamera.position.set(0, 14, 26)\n\nconst renderer = new THREE.WebGLRenderer({ antialias: true })\nrenderer.setSize(window.innerWidth, window.innerHeight)\nrenderer.setPixelRatio(window.devicePixelRatio)\nrenderer.shadowMap.enabled = true\nrenderer.shadowMap.type = THREE.PCFSoftShadowMap\ndocument.getElementById('app')!.appendChild(renderer.domElement)\n\n// ─── Lighting ─────────────────────────────────────────────────────────────────\n\nscene.add(new THREE.AmbientLight(0x223344, 1.8))\n\nconst dirLight = new THREE.DirectionalLight(0xffffff, 2.2)\ndirLight.position.set(12, 20, 12)\ndirLight.castShadow = true\ndirLight.shadow.mapSize.set(1024, 1024)\nscene.add(dirLight)\n\nconst pointLight = new THREE.PointLight(0x4dd0e1, 3, 50)\npointLight.position.set(0, 8, 0)\nscene.add(pointLight)\n\n// ─── Grid ─────────────────────────────────────────────────────────────────────\n\nconst grid = new THREE.GridHelper(60, 60, 0x1a3a5c, 0x112233)\ngrid.position.y = -1.8\nscene.add(grid)\n\n// ─── Controls ─────────────────────────────────────────────────────────────────\n\nconst controls = new OrbitControls(camera, renderer.domElement)\ncontrols.enableDamping = true\ncontrols.dampingFactor = 0.06\ncontrols.minDistance = 3\ncontrols.maxDistance = 100\ncontrols.maxPolarAngle = Math.PI * 0.85\n\n// ─── Graph ────────────────────────────────────────────────────────────────────\n\nconst graph = new NetworkGraph(scene)\n\n// ─── Topology switching ───────────────────────────────────────────────────────\n\nconst topologyInfo = new TopologyInfo()\n\nfunction loadTopology(id: TopologyId): void {\n  graph.clear()\n\n  const meta = getTopology(id)\n  if (!meta) return\n\n  const { nodes, links } = meta.generate()\n\n  for (const nodeDef of nodes) {\n    graph.addNode(nodeDef)\n  }\n  for (const linkDef of links) {\n    graph.addLink({ sourceId: linkDef.sourceId, targetId: linkDef.targetId })\n  }\n\n  topologyInfo.show(meta)\n\n  // Reset camera to fit the new topology\n  camera.position.set(0, 14, 26)\n  controls.target.set(0, 0, 0)\n  controls.update()\n}\n\nconst selector = new TopologySelector((id: TopologyId) => {\n  loadTopology(id)\n})\n\n// Load default topology\nconst defaultId = selector.getFirstId()\nselector.select(defaultId)\n\n// ─── Raycasting / hover tooltip ───────────────────────────────────────────────\n\nconst tooltip = new Tooltip()\nconst raycaster = new THREE.Raycaster()\nconst pointer = new THREE.Vector2()\n\nfunction onPointerMove(event: MouseEvent): void {\n  pointer.x = (event.clientX / window.innerWidth) * 2 - 1\n  pointer.y = -(event.clientY / window.innerHeight) * 2 + 1\n\n  raycaster.setFromCamera(pointer, camera)\n  const meshes = [...graph.nodes.values()].map(n => n.mesh)\n  const intersects = raycaster.intersectObjects(meshes, false)\n\n  if (intersects.length > 0) {\n    const node = intersects[0].object.userData['node'] as NetworkNode\n    document.body.style.cursor = 'pointer'\n    tooltip.show(node, event.clientX, event.clientY)\n  } else {\n    document.body.style.cursor = 'default'\n    tooltip.hide()\n  }\n}\n\nwindow.addEventListener('pointermove', onPointerMove)\n\n// ─── Legend ───────────────────────────────────────────────────────────────────\n\nfunction buildLegend(): void {\n  const legend = document.getElementById('legend')\n  if (!legend) return\n  const items = [\n    { color: '#4fc3f7', label: 'Router' },\n    { color: '#81c784', label: 'Switch' },\n    { color: '#ffb74d', label: 'Server' },\n    { color: '#ce93d8', label: 'Client' },\n    { color: '#4dd0e1', label: 'Enlace activo' },\n  ]\n  legend.innerHTML = items\n    .map(\n      i =>\n        `<div class=\"legend-item\">\n           <span class=\"legend-dot\" style=\"background:${i.color}\"></span>\n           ${i.label}\n         </div>`\n    )\n    .join('')\n}\nbuildLegend()\n\n// ─── Resize ───────────────────────────────────────────────────────────────────\n\nwindow.addEventListener('resize', () => {\n  camera.aspect = window.innerWidth / window.innerHeight\n  camera.updateProjectionMatrix()\n  renderer.setSize(window.innerWidth, window.innerHeight)\n})\n\n// ─── Animation loop ───────────────────────────────────────────────────────────\n\nlet time = 0\n\nfunction animate(): void {\n  requestAnimationFrame(animate)\n  time += 0.008\n  controls.update()\n  graph.update()\n\n  // Gentle floating and rotation per node type\n  for (const node of graph.nodes.values()) {\n    node.mesh.position.y += Math.sin(time * 1.2 + node.mesh.id * 0.9) * 0.002\n    if (node.type === 'router') {\n      node.mesh.rotation.y += 0.007\n    }\n  }\n\n  pointLight.intensity = 2.6 + Math.sin(time * 1.5) * 0.5\n\n  renderer.render(scene, camera)\n}\n\nanimate()"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
