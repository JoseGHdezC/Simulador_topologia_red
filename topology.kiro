                "__tool_use_purpose": "Creating topology metadata with features from the PDF",
                "command": "create",
                "content": "/**\n * topologyMeta.ts\n * Metadata and feature descriptions for each topology, based on Tema 4.\n */\n\nimport {\n  generateMesh,\n  generateTorus,\n  generateWKRecursive,\n  generateFatTree,\n  generateFlattenedButterfly,\n  generateBus,\n  TopologyData,\n} from './topologies'\n\nexport type TopologyId =\n  | 'mesh'\n  | 'torus'\n  | 'wk-recursive'\n  | 'fat-tree'\n  | 'flattened-butterfly'\n  | 'bus'\n\nexport interface TopologyFeature {\n  label: string\n  value: string\n}\n\nexport interface TopologyMeta {\n  id: TopologyId\n  name: string\n  subtitle: string\n  description: string\n  features: TopologyFeature[]\n  generate: () => TopologyData\n}\n\nexport const TOPOLOGIES: TopologyMeta[] = [\n  {\n    id: 'mesh',\n    name: 'Malla (Mesh)',\n    subtitle: 'k-ary 2-mesh — Topología directa ortogonal',\n    description:\n      'Red en malla genérica definida como k-ary n-mesh: k^n switches distribuidos en n dimensiones. ' +\n      'Los switches están acoplados a nodos finales y se conectan con sus vecinos ortogonales. ' +\n      'La malla 2D es el caso más común (n=2). Los hipercubos son el único subconjunto simétrico y homogéneo (2-ary n-mesh). ' +\n      'En general, las k-ary n-mesh no son simétricas ni homogéneas.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Dimensiones', value: '2D (k-ary 2-mesh)' },\n      { label: 'Nº de switches', value: 'k² (ej. 4×4 = 16)' },\n      { label: 'Grado de switch', value: '2–4 (bordes/esquinas vs. interior)' },\n      { label: 'Hop count máx.', value: '2(k−1)  ej. k=4 → 6' },\n      { label: 'Bisection BW', value: 'k × ancho de enlace' },\n      { label: 'Simetría', value: 'No (excepto hipercubo)' },\n      { label: 'Homogeneidad', value: 'No (grado varía en bordes)' },\n      { label: 'Conectividad', value: '2 (nodos de esquina)' },\n      { label: 'Tolerancia a fallos', value: 'Baja en nodos de esquina' },\n      { label: 'Routing típico', value: 'DOR (XY routing)' },\n      { label: 'Uso típico', value: 'Chips multiprocesador, NoC' },\n    ],\n    generate: () => generateMesh(4),\n  },\n  {\n    id: 'torus',\n    name: 'Toroide (Torus)',\n    subtitle: 'k-ary 2-cube — Malla con enlaces circulares',\n    description:\n      'Un toroide se construye añadiendo enlaces \"circulares\" (wrap-around) a la malla equivalente. ' +\n      'Esto reduce el hop count y aumenta el bisection bandwidth y la conectividad respecto a la malla. ' +\n      'A igualdad de k y n, el toroide provee mejor desempeño y tolerancia a fallos que la malla, ' +\n      'a costa de un mayor número de enlaces. El toroide doblado (folded torus) soluciona los problemas de latencia ' +\n      'de los enlaces envolventes largos.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Dimensiones', value: '2D (k-ary 2-cube)' },\n      { label: 'Nº de switches', value: 'k² (ej. 4×4 = 16)' },\n      { label: 'Grado de switch', value: '4 (todos los switches, homogéneo)' },\n      { label: 'Hop count máx.', value: '⌊k/2⌋ × 2  ej. k=4 → 4' },\n      { label: 'Bisection BW', value: '2k × ancho de enlace' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí (todos los switches iguales)' },\n      { label: 'Conectividad', value: '4' },\n      { label: 'Tolerancia a fallos', value: 'Alta (caminos alternativos)' },\n      { label: 'Routing típico', value: 'DOR, XY-YX con canales virtuales' },\n      { label: 'Uso típico', value: 'Supercomputadores, HPC (ej. Cray Torus)' },\n    ],\n    generate: () => generateTorus(4),\n  },\n  {\n    id: 'wk-recursive',\n    name: 'WK-Recursiva',\n    subtitle: 'Topología directa regular no ortogonal',\n    description:\n      'Topología construida replicando recursivamente un nodo virtual (clique de k nodos con k enlaces libres). ' +\n      'Un nodo virtual de nivel l se construye usando k nodos virtuales de nivel l−1. ' +\n      'Parámetros: k (tamaño del clique base) y l (nivel de expansión). ' +\n      'Los enlaces libres de cada grupo de nivel l−1 se usan para interconectar los grupos en el nivel l.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, no ortogonal' },\n      { label: 'Parámetros', value: 'k (grado clique), l (nivel)' },\n      { label: 'Nº de nodos', value: 'k^l  (ej. k=4, l=2 → 16)' },\n      { label: 'Grado de switch', value: 'k−1 intra-grupo + 1 inter-grupo' },\n      { label: 'Hop count máx.', value: 'O(l)' },\n      { label: 'Bisection BW', value: 'k^(l−1) enlaces inter-grupo' },\n      { label: 'Simetría', value: 'Sí (dentro del nivel)' },\n      { label: 'Homogeneidad', value: 'Sí' },\n      { label: 'Conectividad', value: 'k−1' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Recursivo / jerárquico' },\n      { label: 'Uso típico', value: 'NoC, diseños escalables embebidos' },\n    ],\n    generate: () => generateWKRecursive(4, 2),\n  },\n  {\n    id: 'fat-tree',\n    name: 'Fat Tree',\n    subtitle: 'k-ary n-tree — Topología indirecta basada en árbol',\n    description:\n      'Topología regular e indirecta basada en árboles completos que se hacen \"más anchos\" (mayor ancho de banda) ' +\n      'cerca de la raíz. Pertenece a la familia bMIN (bidirectional Multistage Interconnection Network). ' +\n      'Los switches están organizados en etapas; solo los switches de la primera etapa tienen conexión con nodos finales. ' +\n      'Las implementaciones con switches de tamaño fijo se conocen como butterfly fat-tree o folded butterfly.',\n    features: [\n      { label: 'Tipo', value: 'Indirecta, regular, multietapa' },\n      { label: 'Parámetros', value: 'k (grado), n (etapas)' },\n      { label: 'Nº de switches', value: 'k^n − 1 switches  (ej. k=2,n=4 → 15)' },\n      { label: 'Nº de nodos finales', value: 'k^(n−1) × k' },\n      { label: 'Hop count máx.', value: '2(n−1)' },\n      { label: 'Bisection BW', value: 'Crece con k cerca de la raíz' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'No (grado varía por etapa)' },\n      { label: 'Conectividad', value: 'Alta (múltiples caminos raíz)' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Up-Down (up*/down*)' },\n      { label: 'Uso típico', value: 'Centros de datos, clusters HPC (ej. InfiniBand)' },\n    ],\n    generate: () => generateFatTree(2, 4),\n  },\n  {\n    id: 'flattened-butterfly',\n    name: 'Flattened Butterfly',\n    subtitle: 'Evolución del butterfly con switches colapsados',\n    description:\n      'Evolución de la topología butterfly en la que los switches de cada columna se colapsan en un único ' +\n      'switch de mayor grado, manteniendo las conexiones entre switches. La topología resultante es regular y ortogonal, ' +\n      'y provee el mismo bisection bandwidth que la butterfly original pero con un hop count menor, ' +\n      'a costa de un mayor grado de switch.',\n    features: [\n      { label: 'Tipo', value: 'Directa, regular, ortogonal' },\n      { label: 'Parámetros', value: 'p filas, q columnas' },\n      { label: 'Nº de switches', value: 'p × q' },\n      { label: 'Grado de switch', value: '(q−1) + (p−1) (conexiones fila + columna)' },\n      { label: 'Hop count máx.', value: '2 (un salto fila + un salto columna)' },\n      { label: 'Bisection BW', value: 'Igual que butterfly original' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí (todos los switches tienen igual grado)' },\n      { label: 'Conectividad', value: 'Alta' },\n      { label: 'Tolerancia a fallos', value: 'Alta' },\n      { label: 'Routing típico', value: 'Dimension Order, adaptativo' },\n      { label: 'Uso típico', value: 'Datacenters, HPC de alta densidad' },\n    ],\n    generate: () => generateFlattenedButterfly(4, 4),\n  },\n  {\n    id: 'bus',\n    name: 'Bus (Medio Compartido)',\n    subtitle: 'Red de medio compartido — La más simple',\n    description:\n      'La forma más sencilla de conectar varios dispositivos: todos comparten el mismo medio de red. ' +\n      'Solo un dispositivo puede transmitir a la vez. Puede operar en modo half-dúplex (una dirección a la vez) ' +\n      'o full-dúplex. Es la topología con menor coste de implementación pero el cuello de botella ' +\n      'crece rápidamente con el número de nodos, limitando seriamente el ancho de banda total.',\n    features: [\n      { label: 'Tipo', value: 'Medio compartido' },\n      { label: 'Nº de nodos', value: 'N (ej. 8)' },\n      { label: 'Grado de nodo', value: '1 (conexión directa al bus)' },\n      { label: 'Hop count máx.', value: '2 (src → bus → dst)' },\n      { label: 'Bisection BW', value: 'Ancho de banda del bus / 2' },\n      { label: 'Simetría', value: 'Sí' },\n      { label: 'Homogeneidad', value: 'Sí' },\n      { label: 'Conectividad', value: '1 (un único punto de fallo)' },\n      { label: 'Tolerancia a fallos', value: 'Muy baja (SPOF: bus)' },\n      { label: 'Modo operación', value: 'Half-dúplex o Full-dúplex' },\n      { label: 'Routing típico', value: 'Broadcast (todos reciben, filtran por destino)' },\n      { label: 'Uso típico', value: 'Ethernet clásica, buses internos de sistema' },\n    ],\n    generate: () => generateBus(8),\n  },\n]\n\nexport function getTopology(id: TopologyId): TopologyMeta | undefined {\n  return TOPOLOGIES.find(t => t.id === id)\n}\n",
                "path": "network-topology/src/topologyMeta.ts"
              }
            }
          }
        ]
      }
    },
